#!/usr/bin/env python3
"""Task Flow CLI entry point script

This script can be invoked from any working directory and will correctly
locate and run the task-flow CLI.
"""

import os
import sys
from pathlib import Path

# Get the absolute path to this script
SCRIPT_DIR = Path(__file__).parent.resolve()
SRC_DIR = SCRIPT_DIR / "src"
CLI_FILE = SRC_DIR / "cli.py"

# Add src directory to Python path
sys.path.insert(0, str(SRC_DIR))

# Verify the CLI file exists
if not CLI_FILE.exists():
    print(f"Error: CLI file not found at {CLI_FILE}", file=sys.stderr)
    sys.exit(1)

# Execute the CLI module
if __name__ == "__main__":
    # Run cli.py directly using runpy
    import runpy
    runpy.run_path(str(CLI_FILE), run_name="__main__")
